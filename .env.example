AI_GENERATION_API_KEY=
AI_GENERATION_TIMEOUT_SECONDS=1800

# Hermes Agent /v1/runs endpoint.
# If Hermes is in the same compose network, use http://hermes-agent:8642.
# If Hermes is running on host port 18642, use http://host.docker.internal:18642.
HERMES_RUNS_BASE_URL=http://host.docker.internal:18642
HERMES_AGENT_API_KEY=hermes-local-dev-key
HERMES_AGENT_MODEL=gpt-5.5

# Optional platform callback target.
PLATFORM_BASE_URL=
PLATFORM_API_KEY=

# Optional OpenAI-compatible proxy.
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Optional RAGFlow knowledge search.
RAGFLOW_BASE_URL=
RAGFLOW_API_KEY=
RAGFLOW_TIMEOUT_SECONDS=8

